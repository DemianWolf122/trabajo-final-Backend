# --- OBLIGATORIAS ---
MONGO_DB_CONNECTION_STRING=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net
MONGO_DB_NAME=whatsapp
MODE=development
PORT=8080
URL_BACKEND=http://localhost:8080
URL_FRONTEND=http://localhost:5173
JWT_SECRET=<generar un secret de 256 bits, ej. en jwtsecrets.com>
JWT_EXPIRES_IN=7d

# --- OPCIONALES (envio de mail de verificacion) ---
# Sin estas, el link de verificacion se muestra por consola y se devuelve en la respuesta del registro.
GMAIL_USERNAME=
GMAIL_PASSWORD=
